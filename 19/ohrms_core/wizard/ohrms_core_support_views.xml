<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<!--    View of the support ticket submitting form.-->
    <record id="ohrms_core_support_view_form" model="ir.ui.view">
        <field name="name">ohrms.core.support.view.form</field>
        <field name="model">ohrms.core.support</field>
        <field name="arch" type="xml">
            <form string="Open HRMS Core Support"
                  class="o_ohrms_core_support_form">
                <group>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone" widget="phone"/>
                    <field name="priority" widget="priority"/>
                    <field name="subject"/>
                    <field name="description"/>
                    <field name="support_type"/>
                    <field name="category"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </group>
                <group>
                    <field name="show_payload"/>
                    <field name="payload_preview" nolabel="1" colspan="2"
                           invisible="not show_payload" readonly="1"/>
                </group>
                <footer>
                    <button name="confirm_button" type="object" string="Submit"
                            class="btn o_ohrms_core_btn_submit"
                            icon="fa-paper-plane"/>
                    <button name="whatsapp_button" type="object"
                            string="WhatsApp"
                            class="btn o_ohrms_core_btn_whatsapp"
                            icon="fa-whatsapp"/>
                    <button name="cancel" string="Cancel"
                            class="btn o_ohrms_core_btn_cancel"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
